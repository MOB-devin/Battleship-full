{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true
  },
  "extends": ["airbnb-base", "prettier"],
  "overrides": [
    {
      "files": ["**/__tests__/**/*.js", "**/*.test.js"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-plusplus": "off",
    "no-param-reassign": "off",
    "no-console": "warn",
    "no-use-before-define": ["error", { "functions": false, "classes": false }]
  }
}
